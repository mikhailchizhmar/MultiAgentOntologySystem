  <rdf:Description rdf:about="http://fin-ontology.org/ev_Kredit_hasAttribute">
    <rdf:type rdf:resource="http://fin-ontology.org/Evidence"/>
    <fin:about rdf:resource="http://fin-ontology.org/Kredit"/>
    <rdfs:comment xml:lang="ru">лимит</rdfs:comment>
    <rdfs:comment xml:lang="ru">Изменение лимита овердрафта</rdfs:comment>
    <rdfs:comment xml:lang="ru">Срок использования кредита определяется</rdfs:comment>
    <rdfs:comment xml:lang="ru">уплачивает Кредитору проценты из расчета</rdfs:comment>
    <rdfs:comment xml:lang="ru">срок не позднее 5 (Пяти) рабочих дней</rdfs:comment>
    <rdfs:comment xml:lang="ru">уплату задолженности, указанной в п.</rdfs:comment>
    <rdfs:comment xml:lang="ru">являющимися неотъемлемой частью настоящего кредитного договора</rdfs:comment>
    <rdfs:comment xml:lang="ru">УСЛОВИЯ И ПРАВИЛА КРЕДИТОВАНИЯ</rdfs:comment>
    <rdfs:comment xml:lang="ru">УСЛОВИЯ КРЕДИТОВАНИЯ</rdfs:comment>
    <rdfs:comment xml:lang="ru">в пределах суммы установленного лимита</rdfs:comment>
    <rdfs:comment xml:lang="ru">отражения задолженности по кредиту</rdfs:comment>
    <rdfs:comment xml:lang="ru">Сроком использования кредита считается период</rdfs:comment>
    <rdfs:comment xml:lang="ru">проценты (или их часть) и иные причитающиеся с Заемщика денежные средства</rdfs:comment>
    <rdfs:comment xml:lang="ru">счет(а) Кредитора по учету ссудной и иной задолженности</rdfs:comment>
    <rdfs:comment xml:lang="ru">Условий и правил кредитования.</rdfs:comment>
    <rdfs:comment xml:lang="ru">лимита по кредиту</rdfs:comment>
    <rdfs:comment xml:lang="ru">задолженности по кредиту</rdfs:comment>
    <rdfs:comment xml:lang="ru">изменен лимит</rdfs:comment>
    <rdfs:comment xml:lang="ru">срок действия договора</rdfs:comment>
    <rdfs:comment xml:lang="ru">Установленный лимит</rdfs:comment>
    <rdfs:comment xml:lang="ru">установленный лимит</rdfs:comment>
    <rdfs:comment xml:lang="ru">проценты за пользование кредитом</rdfs:comment>
    <rdfs:comment xml:lang="ru">сроков, установленных настоящим договором</rdfs:comment>
    <rdfs:comment xml:lang="ru">Проценты за пользование кредитом</rdfs:comment>
    <rdfs:comment xml:lang="ru">остаток задолженности по основному долгу</rdfs:comment>
    <rdfs:comment xml:lang="ru">сроков, установленных п.</rdfs:comment>
    <rdfs:comment xml:lang="ru">кредитный договор</rdfs:comment>
    <rdfs:comment xml:lang="ru">наличие задолженности по уплате кредита</rdfs:comment>
    <rdfs:comment xml:lang="ru">счета (включая счета в валюте, отличной от валюты кредита)</rdfs:comment>
    <rdfs:comment xml:lang="ru">кредитного договора</rdfs:comment>
    <rdfs:comment xml:lang="ru">кредитного</rdfs:comment>
    <rdfs:comment xml:lang="ru">Условий и правил кредитования</rdfs:comment>
    <rdfs:comment xml:lang="ru">просроченной ссудной задолженности</rdfs:comment>
    <rdfs:comment xml:lang="ru">процентов за просроченную ссудную задолженность</rdfs:comment>
    <rdfs:comment xml:lang="ru">правил кредитования</rdfs:comment>
    <rdfs:comment xml:lang="ru">копию кредитного договора</rdfs:comment>
    <rdfs:comment xml:lang="ru">Количество проверок и их сроки</rdfs:comment>
    <rdfs:comment xml:lang="ru">кредита на срок более 365 и менее 730 дней</rdfs:comment>
    <rdfs:comment xml:lang="ru">по измененной ставке</rdfs:comment>
    <rdfs:comment xml:lang="ru">заплатить проценты по первоначальной процентной ставке</rdfs:comment>
    <rdfs:comment xml:lang="ru">за фактический срок пользования денежными средствами</rdfs:comment>
    <rdfs:comment xml:lang="ru">лимит кредита</rdfs:comment>
    <rdfs:comment xml:lang="ru">Кредитного договора;</rdfs:comment>
    <rdfs:comment xml:lang="ru">кредитного договора;</rdfs:comment>
    <rdfs:comment xml:lang="ru">формирования кредитными организациями резервов на возможные потери по ссудам, ссудной и приравненной к ней задолженности</rdfs:comment>
    <rdfs:comment xml:lang="ru">лимита</rdfs:comment>
    <rdfs:comment xml:lang="ru">кредитования</rdfs:comment>
    <rdfs:comment xml:lang="ru">настоящих</rdfs:comment>
    <rdfs:comment xml:lang="ru">лимита овердрафта</rdfs:comment>
    <rdfs:comment xml:lang="ru">уплатить причитающиеся проценты</rdfs:comment>
    <rdfs:comment xml:lang="ru">уплатить причитающиеся пени</rdfs:comment>
    <rdfs:comment xml:lang="ru">взыскании задолженности</rdfs:comment>
    <rdfs:comment xml:lang="ru">расчетного счета Заемщика</rdfs:comment>
    <rdfs:comment xml:lang="ru">кредит</rdfs:comment>
    <rdfs:comment xml:lang="ru">уменьшает размер лимита</rdfs:comment>
    <rdfs:comment xml:lang="ru">расчетного</rdfs:comment>
    <rdfs:comment xml:lang="ru">расчетного(ых) счета(ов)</rdfs:comment>
    <rdfs:comment xml:lang="ru">уплату процентов за пользование кредитом, в том числе подлежащих уплате до срока возврата кредита</rdfs:comment>
    <rdfs:comment xml:lang="ru">сроков погашения кредита</rdfs:comment>
    <rdfs:comment xml:lang="ru">ставка цифрами и прописью процентов</rdfs:comment>
    <rdfs:comment xml:lang="ru">уплачивает Кредитору пени</rdfs:comment>
    <rdfs:comment xml:lang="ru">суммы просроченной ссудной задолженности</rdfs:comment>
    <rdfs:comment xml:lang="ru">ставка цифрами и прописью процентов от суммы просроченной задолженности</rdfs:comment>
    <rdfs:comment xml:lang="ru">пени из расчета</rdfs:comment>
    <rdfs:comment xml:lang="ru">настоящих условий и правил кредитования</rdfs:comment>
    <rdfs:comment xml:lang="ru">суммы просроченной задолженности</rdfs:comment>
    <rdfs:comment xml:lang="ru">в размере _______________ от суммы лимита</rdfs:comment>
    <rdfs:comment xml:lang="ru">срок предоставления документов</rdfs:comment>
    <rdfs:comment xml:lang="ru">в размере _________________ от суммы лимита</rdfs:comment>
    <rdfs:comment xml:lang="ru">очередность погашения задолженности</rdfs:comment>
    <rdfs:comment xml:lang="ru">изменение сроков возврата кредита</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://fin-ontology.org/Kreditor">
    <fin:issuedBy rdf:resource="http://fin-ontology.org/Kredit"/>
    <fin:issuedBy rdf:resource="http://fin-ontology.org/Overdraft"/>
    <fin:issuedBy rdf:resource="http://fin-ontology.org/Overdrafta"/>
    <fin:issuedBy rdf:resource="http://fin-ontology.org/Kredita"/>
    <fin:requires rdf:resource="http://fin-ontology.org/Overdraft"/>
    <fin:requires rdf:resource="http://fin-ontology.org/Kredit"/>
    <fin:involves rdf:resource="http://fin-ontology.org/Kredit"/>
    <fin:involves rdf:resource="http://fin-ontology.org/Kredita"/>
    <fin:involves rdf:resource="http://fin-ontology.org/Overdraft"/>
    <fin:involves rdf:resource="http://fin-ontology.org/Pogashenie"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://fin-ontology.org/regulatedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ru">регулируется</rdfs:label>
    <rdfs:domain rdf:resource="http://fin-ontology.org/FinancialProduct"/>
    <rdfs:range rdf:resource="http://fin-ontology.org/Actor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://fin-ontology.org/ev_Kredit_requires">
    <rdf:type rdf:resource="http://fin-ontology.org/Evidence"/>
    <fin:about rdf:resource="http://fin-ontology.org/Kredit"/>
    <rdfs:comment xml:lang="ru">с другой стороны, именуемый в дальнейшем «Заемщик»</rdfs:comment>
    <rdfs:comment xml:lang="ru">согласие (акцепт) на списание денежных средств на основании платежного требования Кредитора</rdfs:comment>
    <rdfs:comment xml:lang="ru">Датой предоставления кредита является день осуществления платежа Кредитором с расчетного счета Заемщика</rdfs:comment>
    <rdfs:comment xml:lang="ru">при установлении лимита в течение срока действия договора</rdfs:comment>
    <rdfs:comment xml:lang="ru">сроков, установленных настоящим договором</rdfs:comment>
    <rdfs:comment xml:lang="ru">Заемщик производит уплату процентов</rdfs:comment>
    <rdfs:comment xml:lang="ru">срок, установленного п.</rdfs:comment>
    <rdfs:comment xml:lang="ru">при условии отсутствия у него задолженности</rdfs:comment>
    <rdfs:comment xml:lang="ru">Кредитор имеет право производить списание денежных средств</rdfs:comment>
    <rdfs:comment xml:lang="ru">по истечении срока</rdfs:comment>
    <rdfs:comment xml:lang="ru">Тарифам Кредитора на услуги для юридических лиц</rdfs:comment>
    <rdfs:comment xml:lang="ru">в случае осуществления списания денежных средств согласно кредитному договору</rdfs:comment>
    <rdfs:comment xml:lang="ru">по письменному требованию Кредитора</rdfs:comment>
    <rdfs:comment xml:lang="ru">в случае получения кредита в других банках</rdfs:comment>
    <rdfs:comment xml:lang="ru">проверки реальности финансового-хозяйственной деятельности Заемщика</rdfs:comment>
    <rdfs:comment xml:lang="ru">Кредитор уведомляет Заемщика</rdfs:comment>
    <rdfs:comment xml:lang="ru">перечисления суммы кредита на расчетные счета Заемщика</rdfs:comment>
    <rdfs:comment xml:lang="ru">извещает Заемщика об изменении процентной ставки</rdfs:comment>
    <rdfs:comment xml:lang="ru">по инициативе Кредитора</rdfs:comment>
    <rdfs:comment xml:lang="ru">право требовать от Заемщика уплаты процентов за пользование кредитом</rdfs:comment>
    <rdfs:comment xml:lang="ru">неисполнения либо ненадлежащего исполнения условий иных заключенных договоров с Кредитором;</rdfs:comment>
    <rdfs:comment xml:lang="ru">наличия у Заемщика картотеки расчетных документов, неоплаченных в срок</rdfs:comment>
    <rdfs:comment xml:lang="ru">при несоответствии деятельности Заемщика критериям определения ведения реальной деятельности</rdfs:comment>
    <rdfs:comment xml:lang="ru">настоящих условий</rdfs:comment>
    <rdfs:comment xml:lang="ru">уплатить штрафные неустойки</rdfs:comment>
    <rdfs:comment xml:lang="ru">Отказать в предоставлении кредита для оплаты инкассовых поручений на бесспорное взыскание денежных средств с расчетного счета Заемщика</rdfs:comment>
    <rdfs:comment xml:lang="ru">в уплату задолженности, указанной в п.</rdfs:comment>
    <rdfs:comment xml:lang="ru">обязанности Заемщика для выполнения действий, необходимых для осмотра предмета залога по требованию Кредитора</rdfs:comment>
    <rdfs:comment xml:lang="ru">требованием Кредитора как срок предоставления документов</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://fin-ontology.org/ev_Kredit_issuedBy">
    <rdf:type rdf:resource="http://fin-ontology.org/Evidence"/>
    <fin:about rdf:resource="http://fin-ontology.org/Kredit"/>
    <rdfs:comment xml:lang="ru">Публичное акционерное общество «Уральский банк реконструкции и развития», именуемое в дальнейшем «Кредитор»</rdfs:comment>
    <rdfs:comment xml:lang="ru">по инициативе Кредитора</rdfs:comment>
    <rdfs:comment xml:lang="ru">по требованию Кредитора</rdfs:comment>
    <rdfs:comment xml:lang="ru">издержек Кредитора по получению исполнения от Заемщика</rdfs:comment>
    <rdfs:comment xml:lang="ru">по письменному требованию Кредитора</rdfs:comment>
    <rdfs:comment xml:lang="ru">проверки целевого использования и обеспеченности Кредита</rdfs:comment>
    <rdfs:comment xml:lang="ru">влияют на деятельность Кредитора</rdfs:comment>
    <rdfs:comment xml:lang="ru">Кредитного договора;</rdfs:comment>
    <rdfs:comment xml:lang="ru">существенное снижение чистых активов Заемщика по сравнению с их значением, указанным в финансовой отчетности Заемщика на дату предоставления кредита</rdfs:comment>
    <rdfs:comment xml:lang="ru">к расчетному счету, открытому у Кредитора</rdfs:comment>
    <rdfs:comment xml:lang="ru">в случае, если Заемщик не пользовался лимитом овердрафта</rdfs:comment>
    <rdfs:comment xml:lang="ru">кредитор</rdfs:comment>
    <rdfs:comment xml:lang="ru">заемщика</rdfs:comment>
    <rdfs:comment xml:lang="ru">кредит</rdfs:comment>
    <rdfs:comment xml:lang="ru">кредитор с расчетного(ых) счета(ов), открытого(ых) у Кредитора</rdfs:comment>
    <rdfs:comment xml:lang="ru">Кредитор в одностороннем порядке определять очередность погашения</rdfs:comment>
    <rdfs:comment xml:lang="ru">Перевод Заемщиком своего долга на другое лицо допускается только с письменного согласия Кредитора.</rdfs:comment>
  </rdf:Description>
