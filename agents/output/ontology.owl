  <rdf:Description rdf:about="http://fin-ontology.org/ev_Overdraft_hasAttribute">
    <rdf:type rdf:resource="http://fin-ontology.org/Evidence"/>
    <fin:about rdf:resource="http://fin-ontology.org/Overdraft"/>
    <rdfs:comment xml:lang="ru">расчетного счета</rdfs:comment>
