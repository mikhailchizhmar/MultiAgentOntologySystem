  <rdf:Description rdf:about="http://fin-ontology.org/ev_Zaemschik_issuedBy">
    <rdf:type rdf:resource="http://fin-ontology.org/Evidence"/>
    <fin:about rdf:resource="http://fin-ontology.org/Zaemschik"/>
    <rdfs:comment xml:lang="ru">предоставляет Заемщику кредит в форме овердрафта</rdfs:comment>
    <rdfs:comment xml:lang="ru">Кредитор имеет право производить списание денежных средств с любого принадлежащего Заемщику</rdfs:comment>
    <rdfs:comment xml:lang="ru">предоставлении Заемщику предусмотренного настоящим договором кредита</rdfs:comment>
    <rdfs:comment xml:lang="ru">кредит</rdfs:comment>
    <rdfs:comment xml:lang="ru">заемщик предоставляет согласие на списание денежных средств на основании платежного требования Кредитора</rdfs:comment>
    <rdfs:comment xml:lang="ru">Уведомление или иное сообщение, направляемое Заемщиком Кредитору</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://fin-ontology.org/Protsenty">
    <rdf:type rdf:resource="http://fin-ontology.org/ProductAttribute"/>
    <rdfs:label xml:lang="ru">проценты</rdfs:label>
    <fin:confidence>1.0</fin:confidence>
  </rdf:Description>
