fin:ArbitrazhnyySud a fin:Actor ;
    rdfs:label "арбитражный суд"@ru ;
    fin:confidence "1.0" .

fin:CardProduct a owl:Class ;
    rdfs:label "Карточный продукт"@ru ;
    rdfs:subClassOf fin:FinancialProduct .

fin:DepositProduct a owl:Class ;
    rdfs:label "Депозитный продукт"@ru ;
    rdfs:subClassOf fin:FinancialProduct .

fin:FinancialProductsOntology a owl:Ontology ;
    rdfs:label "Онтология финансовых продуктов"@ru ;
    rdfs:comment "Мультиагентная система. GPT-4o-mini + LangGraph."@ru .

fin:FinansovayaOtchetnost a fin:ProductAttribute ;
    rdfs:label "финансовая отчетность"@ru ;
    fin:confidence "1.0" .

fin:InsuranceProduct a owl:Class ;
    rdfs:label "Страховой продукт"@ru ;
    rdfs:subClassOf fin:FinancialProduct .

fin:InvestmentProduct a owl:Class ;
    rdfs:label "Инвестиционный продукт"@ru ;
    rdfs:subClassOf fin:FinancialProduct .

fin:Litsenziya a fin:LegalTerm ;
    rdfs:label "лицензия"@ru ;
    fin:confidence "1.0" .

fin:NastoyaschikhUsloviyPravil a fin:LegalTerm ;
    rdfs:label "настоящих условий правил"@ru ;
    fin:confidence "0.7" .

fin:PlatezhnoeTrebovanie a fin:LegalTerm ;
    rdfs:label "платежное требование"@ru ;
    fin:confidence "1.0" .

fin:UsloviyPravil a fin:LegalTerm ;
    rdfs:label "условий правил"@ru ;
    fin:confidence "0.7" .

fin:UsloviyPravilKreditovaniya a fin:LegalTerm ;
    rdfs:label "условий правил кредитования"@ru ;
    fin:confidence "0.7" .

fin:appliesTo a owl:ObjectProperty ;
    rdfs:label "применяется к"@ru ;
